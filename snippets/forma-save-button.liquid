<button
  class="forma-save-button {% if style == 'card' %}forma-save-button--card{% else %}forma-save-button--product{% endif %}"
  type="button"
  data-forma-save
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  aria-pressed="false"
>

  <span class="forma-save-button__icon">

    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round">

      <path d="M12 21s-7-4.35-9.5-8C.5 9.5 2.4 5 6.8 5c2.1 0 3.5 1.2 5.2 3 1.7-1.8 3.1-3 5.2-3C21.6 5 23.5 9.5 21.5 13 19 16.65 12 21 12 21z"/>

    </svg>

  </span>

  {% unless style == 'card' %}
    <span class="forma-save-button__label">
      Save to Your Forma
    </span>
  {% endunless %}

</button>