{%- liquid
  assign article_words = article.content | strip_html | split: ' ' | size
  assign reading_time = article_words | divided_by: 220

  if reading_time < 1
    assign reading_time = 1
  endif

  assign article_category = article.tags.first

  if article_category == blank
    assign article_category = blog.title
  endif

  assign article_excerpt = article.excerpt_or_content | strip_html | truncatewords: 24
-%}

<article class="forma-journal-card">
  <a
    href="{{ article.url }}"
    class="forma-journal-card__link"
    aria-label="{{ article.title | escape }}"
  >
    <div class="forma-journal-card__media">
      {%- if article.image != blank -%}
        {{
          article.image
          | image_url: width: 1800
          | image_tag:
            loading: 'lazy',
            widths: '480, 720, 960, 1200, 1500, 1800',
            sizes: '(max-width: 699px) calc(100vw - 32px), 50vw',
            class: 'forma-journal-card__image',
            alt: article.image.alt | default: article.title
        }}
      {%- else -%}
        <div class="forma-journal-card__placeholder">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {%- endif -%}

      <span class="forma-journal-card__arrow" aria-hidden="true">
        ↗
      </span>
    </div>

    <div class="forma-journal-card__content">
      <div class="forma-journal-card__meta">
        {%- if show_category and article_category != blank -%}
          <span>{{ article_category }}</span>
        {%- endif -%}

        <span>{{ reading_time }} min read</span>
      </div>

      <h3 class="forma-journal-card__title">
        {{ article.title }}
      </h3>

      {%- if show_excerpt and article_excerpt != blank -%}
        <p class="forma-journal-card__excerpt">
          {{ article_excerpt }}
        </p>
      {%- endif -%}

      {%- if show_read_more -%}
        <span class="forma-journal-card__read-more">
          Read Article
          <span aria-hidden="true">→</span>
        </span>
      {%- endif -%}
    </div>
  </a>
</article>

<style>
  .forma-journal-card {
    min-width: 0;
  }

  .forma-journal-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

 .forma-journal-card__media {
  position: relative;
  overflow: hidden;
  background: rgb(var(--text-color) / 0.04);
  aspect-ratio: 1.95 / 1;
}

  .forma-journal-card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.5s ease;
  }

  .forma-journal-card__placeholder,
  .forma-journal-card__placeholder svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .forma-journal-card__arrow {
    position: absolute;
    top: 18px;
    right: 18px;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    color: #111;
    background: rgb(255 255 255 / 0.92);
    font-size: 17px;
    line-height: 1;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .forma-journal-card__content {
    padding-top: 20px;
  }

  .forma-journal-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 18px;
    margin-bottom: 15px;
    font-size: 9px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.48;
  }

  .forma-journal-card__meta span + span {
    position: relative;
  }

  .forma-journal-card__meta span + span::before {
    content: "";
    position: absolute;
    top: 50%;
    left: -10px;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: currentColor;
    transform: translateY(-50%);
  }

  .forma-journal-card__title {
    max-width: 620px;
    margin: 0;
    font-size: clamp(23px, 2.2vw, 38px);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .forma-journal-card__excerpt {
    max-width: 580px;
    margin: 15px 0 0;
    font-size: 14px;
    line-height: 1.65;
    opacity: 0.66;
  }

  .forma-journal-card__read-more {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: 24px;
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
    font-size: 10px;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .forma-journal-card__read-more span {
    transition: transform 0.3s ease;
  }

  @media (hover: hover) {
    .forma-journal-card__link:hover
      .forma-journal-card__image {
      transform: scale(1.025);
    }

    .forma-journal-card__link:hover
      .forma-journal-card__arrow {
      opacity: 1;
      transform: translateY(0);
    }

    .forma-journal-card__link:hover
      .forma-journal-card__read-more
      span {
      transform: translateX(4px);
    }
  }

  @media screen and (max-width: 699px) {
    .forma-journal-card__media {
      aspect-ratio: 4 / 3;
    }

    .forma-journal-card__arrow {
      top: 12px;
      right: 12px;
      width: 38px;
      height: 38px;
      opacity: 1;
      transform: none;
    }

    .forma-journal-card__content {
      padding-top: 16px;
    }

    .forma-journal-card__title {
      font-size: 26px;
    }

    .forma-journal-card__excerpt {
      margin-top: 12px;
      font-size: 13px;
    }

    .forma-journal-card__read-more {
      margin-top: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .forma-journal-card__image,
    .forma-journal-card__arrow,
    .forma-journal-card__read-more span {
      transition: none;
    }
  }
</style>