{%- liquid
  assign story_products = article.metafields.custom.shop_the_story.value
  assign story_product_count = story_products.size
-%}

{%- if story_products != blank and story_product_count > 0 -%}
  <section
    id="ShopTheStory-{{ section.id }}"
    class="
      forma-shop-story
      color-scheme
      color-scheme--{{ section.settings.color_scheme.id }}
    "
    data-shop-the-story
  >
    <div class="forma-shop-story__container">
      <header class="forma-shop-story__header">
        <div class="forma-shop-story__heading-group">
          {%- if section.settings.eyebrow != blank -%}
            <p class="forma-shop-story__eyebrow">
              {{ section.settings.eyebrow }}
            </p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="forma-shop-story__heading">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}
        </div>

        {%- if story_product_count > 4 -%}
          <div
            class="forma-shop-story__controls"
            aria-label="Shop the Story navigation"
          >
            <button
              type="button"
              class="forma-shop-story__button"
              data-story-previous
              aria-label="Previous products"
              disabled
            >
              <span aria-hidden="true">←</span>
            </button>

            <button
              type="button"
              class="forma-shop-story__button"
              data-story-next
              aria-label="Next products"
            >
              <span aria-hidden="true">→</span>
            </button>
          </div>
        {%- endif -%}
      </header>

      <div class="forma-shop-story__viewport">
        <div class="forma-shop-story__track" data-story-track tabindex="0" aria-label="Products featured in this story">
          {%- for product in story_products -%}

            <article class="forma-shop-story__item"><a
                href="{{ product.url }}"
                class="forma-shop-story__link"
                aria-label="{{ product.title | escape }}">
                <div class="forma-shop-story__media">
                
                {%- assign editorial_image_url = product.metafields.custom.editorial_image_url.value -%}

                {%- if editorial_image_url != blank -%}
                <img
                src="{{ editorial_image_url | escape }}"
                alt="{{ product.title | escape }}"
                class="forma-shop-story__image"
                loading="lazy"
                width="1200"
                height="1500"
            >

                {%- elsif product.featured_image != blank -%}
                {{
                product.featured_image
                | image_url: width: 1400
                | image_tag:
                    loading: 'lazy',
                    widths: '360, 540, 720, 900, 1100, 1400',
                    sizes: '(max-width: 699px) 82vw, (max-width: 999px) 46vw, 31vw',
                    class: 'forma-shop-story__image',
                    alt: product.featured_image.alt | default: product.title
                }}

  {%- else -%}
    {{
      'product-1'
      | placeholder_svg_tag:
        'forma-shop-story__placeholder'
    }}
  {%- endif -%}

  <span
    class="forma-shop-story__view"
    aria-hidden="true"
  >
    View product
  </span>
</div>

                <div class="forma-shop-story__content">
                  {%- if product.vendor != blank -%}
                    <p class="forma-shop-story__vendor">
                      {{ product.vendor }}
                    </p>
                  {%- endif -%}

                  <h3 class="forma-shop-story__title">
                    {{ product.title }}
                  </h3>

                  <div class="forma-shop-story__price">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="forma-shop-story__price-current">
                        {{ product.price | money }}
                      </span>

                      <s class="forma-shop-story__price-compare">
                        {{ product.compare_at_price | money }}
                      </s>
                    {%- else -%}
                      <span>
                        {{ product.price | money }}
                      </span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            </article>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </section>

  <style>
    #shopify-section-{{ section.id }} {
      --story-gap: clamp(20px, 2vw, 30px);
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story {
      overflow: hidden;
      padding-block:
        clamp(72px, 8vw, 120px)
        clamp(78px, 9vw, 132px);
      background: #f7f5f1;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__container {
      width: min(calc(100% - 64px), 1240px);
      margin-inline: auto;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 32px;
      margin-bottom: clamp(28px, 3vw, 42px);
      padding-top: 20px;
      border-top: 1px solid rgb(var(--text-color) / 0.22);
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__heading-group {
      min-width: 0;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__eyebrow {
      margin: 0 0 10px;
      font-size: 9px;
      font-weight: 500;
      line-height: 1;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      opacity: 0.45;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__heading {
      margin: 0;
      font-size: clamp(28px, 3vw, 44px);
      font-weight: 400;
      line-height: 1;
      letter-spacing: -0.035em;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__controls {
      display: flex;
      flex: none;
      gap: 8px;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__button {
      display: grid;
      place-items: center;
      width: 42px;
      height: 42px;
      padding: 0;
      border: 1px solid rgb(var(--text-color) / 0.2);
      border-radius: 50%;
      color: inherit;
      background: transparent;
      font-size: 16px;
      line-height: 1;
      cursor: pointer;
      transition:
        color 0.25s ease,
        background 0.25s ease,
        border-color 0.25s ease,
        opacity 0.25s ease;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__button:disabled {
      opacity: 0.25;
      cursor: default;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__viewport {
      width: calc(
        100vw -
        max(
          32px,
          calc((100vw - 1240px) / 2)
        )
      );
      overflow: visible;
    }


    grid-auto-columns:
    minmax(0, calc((100% - (var(--story-gap) * 3)) / 4.15));

    #shopify-section-{{ section.id }} .forma-shop-story__track {
  display: flex;
  gap: var(--story-gap);

  width: 100%;
  overflow-x: auto;
  overflow-y: hidden;

  margin: 0;
  padding: 0 32px 14px 0;

  scroll-behavior: smooth;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  overscroll-behavior-inline: contain;
  -webkit-overflow-scrolling: touch;
}

#shopify-section-{{ section.id }} .forma-shop-story__track::-webkit-scrollbar {
  display: none;
}

    #shopify-section-{{ section.id }}
      .forma-shop-story__track::-webkit-scrollbar {
      display: none;
    }

    #shopify-section-{{ section.id }} .forma-shop-story__item {
  flex: 0 0 calc((100% - (var(--story-gap) * 3)) / 4.15);
  min-width: 0;
  scroll-snap-align: start;
}

#shopify-section-{{ section.id }} .forma-shop-story__media {
  position: relative;
  overflow: hidden;
  width: 100%;
  aspect-ratio: 4 / 5;
  background: transparent !important;
}

    #shopify-section-{{ section.id }}
      .forma-shop-story__link {
      display: block;
      color: inherit;
      text-decoration: none;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__media {
      position: relative;
      overflow: hidden;
      aspect-ratio: 4 / 5;
      background: transparent !important;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__image,
    #shopify-section-{{ section.id }}
      .forma-shop-story__placeholder {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition:
        transform 0.85s cubic-bezier(0.22, 1, 0.36, 1),
        filter 0.4s ease;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__view {
      position: absolute;
      right: 14px;
      bottom: 14px;
      padding: 10px 14px;
      color: #111;
      background: #f7f5f1
      font-size: 9px;
      font-weight: 500;
      line-height: 1;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity 0.3s ease,
        transform 0.3s ease;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__content {
      padding-top: 19px;
    }

    #shopify-section-{{ section.id }}
    .forma-shop-story__vendor {
  margin: 0 0 10px;
  font-size: 9px;
  font-weight: 500;
  line-height: 1;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  opacity: 0.52;
}

    #shopify-section-{{ section.id }}
      .forma-shop-story__title {
      margin: 0;
    font-size: clamp(19px, 1.65vw, 24px);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__price {
      display: flex;
      align-items: center;
      gap: 9px;
      margin-top: 9px;
      font-size: 11px;
      line-height: 1.2;
      opacity: 0.68;
    }

    #shopify-section-{{ section.id }}
      .forma-shop-story__price-compare {
      opacity: 0.55;
    }

    @media (hover: hover) {
      #shopify-section-{{ section.id }}
        .forma-shop-story__link:hover
        .forma-shop-story__image {
        transform: scale(1.025);
        filter: brightness(1.025);
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__link:hover
        .forma-shop-story__view {
        opacity: 1;
        transform: translateY(0);
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__button:not(:disabled):hover {
        color: rgb(var(--background));
        background: rgb(var(--text-color));
        border-color: rgb(var(--text-color));
      }
    }

   @media screen and (max-width: 999px) {
  #shopify-section-{{ section.id }}
    .forma-shop-story__track {
    grid-auto-columns: minmax(0, 44%);
  }
}

    @media screen and (max-width: 699px) {
      #shopify-section-{{ section.id }}
        .forma-shop-story {
        padding-block: 58px 78px;
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__container {
        width: min(calc(100% - 32px), 1240px);
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__header {
        margin-bottom: 24px;
        padding-top: 17px;
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__heading {
        font-size: 29px;
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__controls {
        display: none;
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__viewport {
        width: calc(100vw - 16px);
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__track {
        grid-auto-columns: minmax(0, 84%);
        gap: 14px;
        padding-right: 16px;
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__view {
        opacity: 1;
        transform: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #shopify-section-{{ section.id }}
        .forma-shop-story__track {
        scroll-behavior: auto;
      }

      #shopify-section-{{ section.id }}
        .forma-shop-story__image,
      #shopify-section-{{ section.id }}
        .forma-shop-story__view {
        transition: none;
      }
    }

    /* FORMA – definitive Shop the Story slider fix */
#shopify-section-{{ section.id }} .forma-shop-story__viewport {
  width: 100% !important;
  max-width: 100% !important;
  overflow: hidden !important;
}

#shopify-section-{{ section.id }} .forma-shop-story__track {
  display: flex !important;
  flex-wrap: nowrap !important;
  align-items: flex-start !important;

  width: 100% !important;
  max-width: 100% !important;

  gap: 24px !important;
  overflow-x: auto !important;
  overflow-y: hidden !important;

  margin: 0 !important;
  padding: 0 0 16px !important;

  scroll-snap-type: x mandatory !important;
  scroll-behavior: smooth !important;
  scrollbar-width: none !important;
  -webkit-overflow-scrolling: touch !important;
}

#shopify-section-{{ section.id }}
  .forma-shop-story__track::-webkit-scrollbar {
  display: none !important;
}

#shopify-section-{{ section.id }} .forma-shop-story__item {
  display: block !important;

  flex: 0 0 calc((100% - 72px) / 4.2) !important;
  width: calc((100% - 72px) / 4.2) !important;
  max-width: calc((100% - 72px) / 4.2) !important;
  min-width: 0 !important;

  scroll-snap-align: start !important;
}

#shopify-section-{{ section.id }} .forma-shop-story__link {
  display: block !important;
  width: 100% !important;
}

#shopify-section-{{ section.id }} .forma-shop-story__media {
  position: relative !important;
  display: block !important;

  width: 100% !important;
  height: auto !important;
  aspect-ratio: 4 / 5 !important;
background: transparent !important;
  overflow: hidden !important;
}

#shopify-section-{{ section.id }} .forma-shop-story__image,
#shopify-section-{{ section.id }} .forma-shop-story__placeholder {
  display: block !important;

  width: 100% !important;
  height: 100% !important;
  max-width: 100% !important;

  object-fit: cover !important;
}

/* Tablet */
@media screen and (max-width: 999px) {
  #shopify-section-{{ section.id }} .forma-shop-story__item {
    flex-basis: calc((100% - 20px) / 2.2) !important;
    width: calc((100% - 20px) / 2.2) !important;
    max-width: calc((100% - 20px) / 2.2) !important;
  }
}

/* Mobile */
@media screen and (max-width: 699px) {
  #shopify-section-{{ section.id }} .forma-shop-story__track {
    gap: 14px !important;
    padding-right: 16px !important;
  }

  #shopify-section-{{ section.id }} .forma-shop-story__item {
    flex-basis: 82% !important;
    width: 82% !important;
    max-width: 82% !important;
  }
}
  </style>

  <script>
    (() => {
      const section = document.getElementById(
        'ShopTheStory-{{ section.id }}'
      );

      if (
        !section ||
        section.dataset.storyInitialized === 'true'
      ) {
        return;
      }

      section.dataset.storyInitialized = 'true';

      const track = section.querySelector(
        '[data-story-track]'
      );

      const previousButton = section.querySelector(
        '[data-story-previous]'
      );

      const nextButton = section.querySelector(
        '[data-story-next]'
      );

      if (!track) {
        return;
      }

      const getDistance = () => {
        const item = track.querySelector(
          '.forma-shop-story__item'
        );

        if (!item) {
          return track.clientWidth * 0.75;
        }

        const styles = window.getComputedStyle(track);

        const gap =
          parseFloat(
            styles.columnGap || styles.gap
          ) || 0;

        return (
          item.getBoundingClientRect().width +
          gap
        );
      };

      const updateButtons = () => {
        if (!previousButton || !nextButton) {
          return;
        }

        const maximumScroll =
          track.scrollWidth -
          track.clientWidth -
          2;

        previousButton.disabled =
          track.scrollLeft <= 2;

        nextButton.disabled =
          track.scrollLeft >= maximumScroll;
      };

      if (previousButton) {
        previousButton.addEventListener(
          'click',
          () => {
            track.scrollBy({
              left: -getDistance(),
              behavior: 'smooth'
            });
          }
        );
      }

      if (nextButton) {
        nextButton.addEventListener(
          'click',
          () => {
            track.scrollBy({
              left: getDistance(),
              behavior: 'smooth'
            });
          }
        );
      }

      track.addEventListener(
        'scroll',
        () => {
          window.requestAnimationFrame(
            updateButtons
          );
        },
        { passive: true }
      );

      window.addEventListener(
        'resize',
        updateButtons
      );

      updateButtons();
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Shop the Story",
  "class": "shopify-section--shop-the-story",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "inline_richtext",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured in this article"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Story"
    }
  ],
  "presets": [
    {
      "name": "Shop the Story"
    }
  ]
}
{% endschema %}