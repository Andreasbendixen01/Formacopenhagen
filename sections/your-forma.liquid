<section
  class="forma-dashboard"
  data-forma-dashboard
>
  <div class="forma-dashboard__container">

    <header class="forma-dashboard__hero" data-forma-dashboard-hero>
  <div class="forma-dashboard__hero-main">
    <p class="forma-dashboard__eyebrow" data-forma-hero-eyebrow>
      Your Forma
    </p>

    <h1 class="forma-dashboard__title">
      <span data-forma-hero-greeting>
        Welcome back
      </span><span data-forma-profile-name></span>.
    </h1>

    <p
      class="forma-dashboard__hero-message"
      data-forma-hero-message
    >
      Your personal world of design, fashion and places.
    </p>
  </div>

  <div class="forma-dashboard__hero-footer">
    <p
      class="forma-dashboard__hero-context"
      data-forma-hero-context
    >
      Curated by your journey.
    </p>

    <button
      type="button"
      class="forma-dashboard__edit-profile"
      data-forma-edit-profile
    >
      <span>Edit profile</span>
      <span aria-hidden="true">→</span>
    </button>
  </div>
</header>

    <section class="forma-dashboard__overview">
      <div class="forma-dashboard__overview-item">
        <span
          class="forma-dashboard__overview-value"
          data-forma-following-count
        >
          0
        </span>

        <span class="forma-dashboard__overview-label">
          Following
        </span>
      </div>

      <div class="forma-dashboard__overview-item">
        <span
          class="forma-dashboard__overview-value"
          data-forma-saved-count
        >
          0
        </span>

        <span class="forma-dashboard__overview-label">
          Saved
        </span>
      </div>

      <div class="forma-dashboard__overview-item">
        <span
          class="forma-dashboard__overview-value"
          data-forma-recent-count
        >
          0
        </span>

        <span class="forma-dashboard__overview-label">
          Viewed
        </span>
      </div>

      <div class="forma-dashboard__overview-item">
        <span
          class="forma-dashboard__overview-value"
          data-forma-profile-status
