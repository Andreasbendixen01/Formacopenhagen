{% style %}

/* ==========================================================
   FORMA — DASHBOARD ENTRANCE ANIMATION
   ========================================================== */

[data-forma-dashboard].is-managed
.forma-dashboard-section {
  opacity: 0;
  transform: translateY(18px);
  transition:
    opacity 420ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform;
}

[data-forma-dashboard].is-managed
.forma-dashboard-section.is-visible {
  opacity: 1;
  transform: translateY(0);
}

@media (prefers-reduced-motion: reduce) {
  [data-forma-dashboard].is-managed
  .forma-dashboard-section {
    opacity: 1;
    transform: none;
    transition: none;
  }
}


/* ==========================================================
   FORMA — NEW ARRIVALS SKELETON
   ========================================================== */

.forma-new-arrivals__skeleton[hidden] {
  display: none !important;
}

.forma-new-arrivals__skeleton {
  overflow: hidden;
  border-top: 1px solid rgba(23, 23, 23, 0.16);
  transition:
    opacity 320ms ease,
    visibility 320ms ease;
}

.forma-new-arrivals__skeleton.is-leaving {
  opacity: 0;
  visibility: hidden;
}

.forma-new-arrivals__skeleton-row {
  position: relative;
  min-height: 126px;
  display: grid;
  grid-template-columns: 70px minmax(0, 1fr) 150px 34px;
  align-items: center;
  gap: 24px;
  border-bottom: 1px solid rgba(23, 23, 23, 0.16);
}

.forma-new-arrivals__skeleton-row::after {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    100deg,
    transparent 20%,
    rgba(255, 255, 255, 0.62) 48%,
    transparent 76%
  );
  content: "";
  transform: translateX(-110%);
  animation: forma-skeleton-shimmer 1.55s ease-in-out infinite;
  pointer-events: none;
}

.forma-new-arrivals__skeleton-row:nth-child(2)::after {
  animation-delay: 120ms;
}

.forma-new-arrivals__skeleton-row:nth-child(3)::after {
  animation-delay: 240ms;
}

.forma-new-arrivals__skeleton-index,
.forma-new-arrivals__skeleton-name,
.forma-new-arrivals__skeleton-count,
.forma-new-arrivals__skeleton-icon {
  display: block;
  background: rgba(23, 23, 23, 0.075);
}

.forma-new-arrivals__skeleton-index {
  width: 22px;
  height: 8px;
}

.forma-new-arrivals__skeleton-name {
  width: min(340px, 64%);
  height: clamp(26px, 3vw, 45px);
}

.forma-new-arrivals__skeleton-count {
  width: 116px;
  height: 10px;
  justify-self: end;
}

.forma-new-arrivals__skeleton-icon {
  width: 20px;
  height: 1px;
  justify-self: center;
}

@keyframes forma-skeleton-shimmer {
  to {
    transform: translateX(110%);
  }
}

@media screen and (max-width: 749px) {
  .forma-new-arrivals__skeleton-row {
    min-height: 104px;
    grid-template-columns: 34px minmax(0, 1fr) 32px 24px;
    gap: 12px;
  }

  .forma-new-arrivals__skeleton-name {
    width: 72%;
    height: 29px;
  }

  .forma-new-arrivals__skeleton-count {
    width: 22px;
    height: 9px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .forma-new-arrivals__skeleton-row::after {
    animation: none;
  }
}

/* ==========================================================
   FORMA — DASHBOARD POLISH
   ========================================================== */

.forma-dashboard-section {
  position: relative;
  margin-top: clamp(96px, 10vw, 176px);
}

.forma-dashboard-section:first-child {
  margin-top: 0;
}

.forma-dashboard-section__header {
  margin-bottom: clamp(34px, 4.5vw, 70px);
}

.forma-dashboard-section__heading {
  max-width: 920px;
}

.forma-dashboard-section__eyebrow {
  margin-bottom: 20px;
}

.forma-dashboard-section__title {
  text-wrap: balance;
}

.forma-dashboard-section__description {
  max-width: 620px;
  margin-top: 22px;
  text-wrap: pretty;
}

/* Reveal system */

.forma-reveal-section {
  opacity: 0;
  transform: translateY(38px);
  transition:
    opacity 760ms
      cubic-bezier(0.22, 1, 0.36, 1),
    transform 920ms
      cubic-bezier(0.22, 1, 0.36, 1);
  will-change:
    opacity,
    transform;
}

.forma-reveal-section.is-revealed {
  opacity: 1;
  transform: translateY(0);
}

.forma-reveal-item {
  opacity: 0;
  transform: translateY(22px);
  transition:
    opacity 620ms
      cubic-bezier(0.22, 1, 0.36, 1),
    transform 760ms
      cubic-bezier(0.22, 1, 0.36, 1);

  transition-delay:
    calc(
      90ms +
      var(--forma-reveal-index, 0)
      * 55ms
    );
}

.forma-reveal-section.is-revealed
.forma-reveal-item {
  opacity: 1;
  transform: translateY(0);
}

/* Subtle separator rhythm */

.forma-dashboard-section
+ .forma-dashboard-section::before {
  position: absolute;
  top: calc(
    clamp(96px, 10vw, 176px) / -2
  );
  left: 0;
  width: 100%;
  height: 1px;
  background:
    linear-gradient(
      90deg,
      rgba(23, 23, 23, 0),
      rgba(23, 23, 23, 0.13) 12%,
      rgba(23, 23, 23, 0.13) 88%,
      rgba(23, 23, 23, 0)
    );
  content: "";
}

/* Premium interactive movement */

.forma-dashboard-section a,
.forma-dashboard-section button {
  -webkit-tap-highlight-color:
    transparent;
}

.forma-dashboard-section a:focus-visible,
.forma-dashboard-section button:focus-visible {
  outline:
    1px solid rgba(23, 23, 23, 0.75);
  outline-offset: 5px;
}

.forma-new-product__media,
.forma-continue-card__media,
.forma-discover-card__media {
  transition:
    transform 520ms
      cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 520ms
      cubic-bezier(0.22, 1, 0.36, 1);
}

@media (hover: hover) {
  .forma-new-product:hover
  .forma-new-product__media,
  .forma-continue-card:hover
  .forma-continue-card__media,
  .forma-discover-card:hover
  .forma-discover-card__media {
    transform: translateY(-5px);
    box-shadow:
      0 24px 50px
      rgba(23, 23, 23, 0.08);
  }
}

@media screen and (max-width: 749px) {
  .forma-dashboard-section {
    margin-top: 92px;
  }

  .forma-dashboard-section__header {
    margin-bottom: 32px;
  }

  .forma-dashboard-section
  + .forma-dashboard-section::before {
    top: -46px;
  }

  .forma-reveal-section {
    transform: translateY(24px);
  }

  .forma-reveal-item {
    transform: translateY(15px);
  }
}

@media (
  prefers-reduced-motion: reduce
) {
  .forma-reveal-section,
  .forma-reveal-item {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }

  .forma-new-product__media,
  .forma-continue-card__media,
  .forma-discover-card__media {
    transition: none !important;
  }
}

/* ==========================================================
   FORMA — SINCE YOUR LAST VISIT
   ========================================================== */

.forma-new-arrivals[hidden],
.forma-new-arrivals__empty[hidden] {
  display: none !important;
}

.forma-new-arrivals__total {
  margin: 0;
  color: rgba(23, 23, 23, 0.48);
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.forma-new-arrivals__list {
  border-top: 1px solid rgba(23, 23, 23, 0.16);
}

.forma-new-brand {
  border-bottom: 1px solid rgba(23, 23, 23, 0.16);
}

.forma-new-brand__trigger {
  width: 100%;
  min-height: 126px;
  display: grid;
  grid-template-columns: 70px minmax(0, 1fr) auto 34px;
  align-items: center;
  gap: 24px;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  text-align: left;
  cursor: pointer;
}

.forma-new-brand__index {
  color: rgba(23, 23, 23, 0.38);
  font-size: 10px;
  letter-spacing: 0.16em;
}

.forma-new-brand__name {
  margin: 0;
  font-size: clamp(27px, 3.2vw, 52px);
  font-weight: 400;
  line-height: 1;
  letter-spacing: -0.045em;
  transition:
    opacity 200ms ease,
    transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
}

.forma-new-brand__count {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  color: rgba(23, 23, 23, 0.54);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.forma-new-brand__count-number {
  color: #171717;
  font-size: 14px;
  letter-spacing: 0;
}

.forma-new-brand__icon {
  position: relative;
  width: 24px;
  height: 24px;
}

.forma-new-brand__icon::before,
.forma-new-brand__icon::after {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 15px;
  height: 1px;
  background: currentColor;
  content: "";
  transform: translate(-50%, -50%);
  transition: transform 260ms ease;
}

.forma-new-brand__icon::after {
  transform: translate(-50%, -50%) rotate(90deg);
}

.forma-new-brand__trigger[aria-expanded="true"]
.forma-new-brand__icon::after {
  transform: translate(-50%, -50%) rotate(0deg);
}

.forma-new-brand__trigger:hover
.forma-new-brand__name {
  opacity: 0.58;
  transform: translateX(7px);
}

.forma-new-brand__panel {
  display: grid;
  grid-template-rows: 0fr;
  opacity: 0;
  visibility: hidden;
  transition:
    grid-template-rows 520ms cubic-bezier(0.22, 1, 0.36, 1),
    opacity 300ms ease,
    visibility 0s linear 520ms;
}

.forma-new-brand.is-open
.forma-new-brand__panel {
  grid-template-rows: 1fr;
  opacity: 1;
  visibility: visible;
  transition:
    grid-template-rows 520ms cubic-bezier(0.22, 1, 0.36, 1),
    opacity 380ms ease 100ms,
    visibility 0s;
}

.forma-new-brand__panel-inner {
  min-height: 0;
  overflow: hidden;
}

.forma-new-brand__content {
